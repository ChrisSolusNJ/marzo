function agruparPorCategoria(array $dataPlanProduccion): array
{
    $categorias = [];

    foreach ($dataPlanProduccion as $idProducto => $rows) {

        foreach ($rows as $r) {

            $categoria = $r['Categoria'] ?? 'SIN CATEGORIA';
            $idProd    = $r['idProducto'];

            if (!isset($categorias[$categoria])) {
                $categorias[$categoria] = [];
            }

            if (!isset($categorias[$categoria][$idProd])) {
                $categorias[$categoria][$idProd] = [];
            }

            // 🔥 aquí está la clave: separas por categoría
            $categorias[$categoria][$idProd][] = $r;
        }
    }

    ksort($categorias, SORT_NATURAL);

    return $categorias;
}