import win32com.client

opc = win32com.client.Dispatch("OPC.Automation.1")
opc.Connect("RSLinx OPC Server")

group = opc.OPCGroups.Add("Test")

base = "[MMC-MP16]Mes_ReporteParos"

for v in range(10):
    tag = f"{base}[0,1,{v}]"

    item = group.OPCItems.AddItem(tag, v)

    valor, calidad, ts = item.Read(1)

    print(tag, "=", valor)

opc.Disconnect()