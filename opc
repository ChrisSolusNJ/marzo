import win32com.client
from typing import List, Dict, Any


def obtener_paros_activos_completos() -> List[Dict[str, Any]]:
    """
    Retorna una lista de diccionarios con todos los paros activos del TURNO 0 (actual)
    """
    try:
        # Conexión OPC
        opc = win32com.client.Dispatch("OPC.Automation.1")
        opc.Connect("RSLinx OPC Server")

        group = opc.OPCGroups.Add("GrupoParosCompletos")
        group.IsActive = True

        base_tag = "[MMC-MP16]Mes_ReporteParos"
        turno_actual = 0  # SOLO TURNO 0
        paros_completos = []

        print("Buscando paros activos en TURNO 0 (actual)...")

        # Primero identificar qué paros tienen tiempo de paro > 0 en TURNO 0
        paros_activos = []
        for np in range(50):
            tag_tiempo = f"{base_tag}[{turno_actual},{np},2]"

            try:
                item = group.OPCItems.AddItem(tag_tiempo, np + 1000)
                tiempo_paro, calidad, ts = item.Read(1)

                if tiempo_paro > 0:
                    paros_activos.append(np)
                    print(f"✓ Paro {np} activo - Tiempo: {tiempo_paro} minutos")

            except Exception as e:
                print(f"Error leyendo paro {np}: {e}")
                continue

        print(f"Encontrados {len(paros_activos)} paros activos en el turno 0")

        # Para cada paro activo, leer todos sus valores
        for np in paros_activos:
            print(f"Leyendo datos completos del paro {np}...")

            # Diccionario con todos los valores del paro
            valores_paro = {}

            # Leer cada uno de los 10 valores
            for v in range(10):
                tag = f"{base_tag}[{turno_actual},{np},{v}]"

                try:
                    item_id = (np * 20) + v + 2000
                    item = group.OPCItems.AddItem(tag, item_id)
                    valor, calidad, ts = item.Read(1)

                    # Asignar nombre según el índice
                    if v == 0:
                        valores_paro["cortes"] = int(valor) if valor else 0
                    elif v == 1:
                        valores_paro["rechazos"] = int(valor) if valor else 0
                    elif v == 2:
                        valores_paro["tiempo_paro"] = float(valor) if valor else 0.0
                    elif v == 3:
                        valores_paro["hora"] = int(valor) if valor else 0
                    elif v == 4:
                        valores_paro["minuto"] = int(valor) if valor else 0
                    elif v == 5:
                        valores_paro["segundo"] = int(valor) if valor else 0
                    elif v == 6:
                        valores_paro["dia"] = int(valor) if valor else 0
                    elif v == 7:
                        valores_paro["mes"] = int(valor) if valor else 0
                    elif v == 8:
                        valores_paro["año"] = int(valor) if valor else 0
                    elif v == 9:
                        valores_paro["spare"] = valor

                except Exception as e:
                    print(f"Error leyendo valor {v} del paro {np}: {e}")
                    # Si hay error, asignar 0
                    if v == 0:
                        valores_paro["cortes"] = 0
                    elif v == 1:
                        valores_paro["rechazos"] = 0
                    elif v == 2:
                        valores_paro["tiempo_paro"] = 0.0
                    elif v == 3:
                        valores_paro["hora"] = 0
                    elif v == 4:
                        valores_paro["minuto"] = 0
                    elif v == 5:
                        valores_paro["segundo"] = 0
                    elif v == 6:
                        valores_paro["dia"] = 0
                    elif v == 7:
                        valores_paro["mes"] = 0
                    elif v == 8:
                        valores_paro["año"] = 0
                    elif v == 9:
                        valores_paro["spare"] = 0

            # Crear el objeto del paro
            paro_completo = {
                "turno": turno_actual,
                "numero_paro": np,
                "valores": valores_paro
            }

            paros_completos.append(paro_completo)

        opc.Disconnect()
        print(f"Proceso completado. Encontrados {len(paros_completos)} paros activos en el turno 0.")
        return paros_completos

    except Exception as e:
        print(f"Error general: {e}")
        return []


def mostrar_paros_formateados(paros_completos: List[Dict[str, Any]]):
    """Muestra los paros en el formato que solicitaste"""

    if not paros_completos:
        print("No se encontraron paros activos en el turno 0")
        return

    for i, paro in enumerate(paros_completos, 1):
        print(f"\n{'=' * 50}")
        print(f"PARO {i}")
        print(f"{'=' * 50}")
        print(f"Turno actual: {paro['turno']}")
        print(f"Paro {paro['numero_paro']}")
        print("Valores:")

        valores = paro['valores']

        print(f"  • Cortes: {valores.get('cortes', 0)}")
        print(f"  • Rechazos: {valores.get('rechazos', 0)}")
        print(f"  • Tiempo paro: {valores.get('tiempo_paro', 0):.2f} minutos")

        # Formatear hora
        hora = valores.get('hora', 0)
        minuto = valores.get('minuto', 0)
        segundo = valores.get('segundo', 0)
        print(f"  • Hora: {hora:02d}:{minuto:02d}:{segundo:02d}")

        # Formatear fecha
        dia = valores.get('dia', 0)
        mes = valores.get('mes', 0)
        año = valores.get('año', 0)
        print(f"  • Fecha: {dia:02d}/{mes:02d}/{año}")

        print(f"  • Spare: {valores.get('spare', 0)}")


# USO PRINCIPAL
if __name__ == "__main__":
    # Obtener todos los paros activos con sus valores completos DEL TURNO 0
    paros = obtener_paros_activos_completos()

    # Mostrar en el formato solicitado
    mostrar_paros_formateados(paros)

